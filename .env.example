# Supabase Configuration (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare deployment variables (required for Pages/Workers deployment)
VITE_CLOUDFLARE_ACCOUNT_ID=
VITE_CLOUDFLARE_PROJECT_NAME=

# Optional Cloudflare worker route/binding name if used by your deployment scripts
VITE_CLOUDFLARE_WORKER_NAME=

# Optional Gemini AI key (only needed when AI features are enabled)
GEMINI_API_KEY=
