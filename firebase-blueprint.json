{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user or business owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "name": { "type": "string", "description": "The full name of the user." },
        "email": { "type": "string", "description": "The email address of the user." },
        "avatar": { "type": "string", "description": "The URL of the user's profile picture." },
        "role": { "type": "string", "enum": ["user", "owner", "admin"], "description": "The role of the user." },
        "businessId": { "type": "string", "description": "The ID of the business owned by this user (if role is owner)." }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Post": {
      "title": "Social Post",
      "description": "A post shared by a business owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the post." },
        "businessId": { "type": "string", "description": "The ID of the business that created the post." },
        "businessName": { "type": "string", "description": "The name of the business at the time of posting." },
        "businessAvatar": { "type": "string", "description": "The avatar of the business at the time of posting." },
        "caption": { "type": "string", "description": "The text content of the post." },
        "imageUrl": { "type": "string", "description": "The URL of the image shared in the post." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the post was created." },
        "likes": { "type": "integer", "description": "The number of likes the post has received." },
        "verified": { "type": "boolean", "description": "Whether the business was verified at the time of posting." }
      },
      "required": ["id", "businessId", "caption", "createdAt", "likes"]
    },
    "Business": {
      "title": "Business Directory Entry",
      "description": "Information about a business in the directory.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the business." },
        "name": { "type": "string", "description": "The name of the business (English)." },
        "nameAr": { "type": "string", "description": "The name of the business (Arabic)." },
        "nameKu": { "type": "string", "description": "The name of the business (Kurdish)." },
        "category": { "type": "string", "description": "The primary category ID." },
        "subcategory": { "type": "string", "description": "The subcategory ID." },
        "governorate": { "type": "string", "description": "The governorate where the business is located." },
        "city": { "type": "string", "description": "The city where the business is located." },
        "address": { "type": "string", "description": "The full address of the business." },
        "phone": { "type": "string", "description": "The contact phone number." },
        "description": { "type": "string", "description": "A description of the business." },
        "imageUrl": { "type": "string", "description": "The main image URL." },
        "coverImage": { "type": "string", "description": "The cover image URL." },
        "lat": { "type": "number", "description": "The latitude coordinate." },
        "lng": { "type": "number", "description": "The longitude coordinate." },
        "rating": { "type": "number", "description": "The average rating of the business." },
        "reviewCount": { "type": "integer", "description": "The total number of reviews." },
        "isVerified": { "type": "boolean", "description": "Whether the business is verified." },
        "isFeatured": { "type": "boolean", "description": "Whether the business is featured." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags associated with the business." },
        "priceRange": { "type": "integer", "description": "Price range from 1 to 4." },
        "openHours": { "type": "string", "description": "The opening hours of the business." }
      },
      "required": ["id", "name", "category", "governorate", "city"]
    },
    "Like": {
      "title": "Post Like",
      "description": "A record of a user liking a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who liked the post." },
        "postId": { "type": "string", "description": "The ID of the post that was liked." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the like was created." }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "BusinessPostcard": {
      "title": "Business Postcard",
      "description": "High-quality business data generated by the AI Data Architect.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the business." },
        "city": { "type": "string", "description": "The city (governorate capital)." },
        "neighborhood": { "type": "string", "description": "The sub-area or district." },
        "governorate": { "type": "string", "description": "The governorate." },
        "category_tag": { "type": "string", "enum": ["Cafe", "Restaurant", "Bakery", "Hotel", "Gym", "Salon", "Pharmacy", "Supermarket"], "description": "The category." },
        "phone": { "type": "string", "description": "The Iraqi phone number (+964)." },
        "website": { "type": "string", "description": "The business website URL." },
        "instagram": { "type": "string", "description": "The Instagram handle." },
        "hero_image": { "type": "string", "description": "The main high-res image URL." },
        "image_gallery": { "type": "array", "items": { "type": "string" }, "description": "A gallery of at least 3 images." },
        "postcard_content": { "type": "string", "description": "The AI-generated tagline." },
        "google_maps_url": { "type": "string", "description": "The Google Maps CID URL." },
        "rating": { "type": "number", "description": "The average rating." },
        "review_count": { "type": "integer", "description": "The total number of reviews." },
        "verified": { "type": "boolean", "description": "Whether the business is verified." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update timestamp." }
      },
      "required": ["title", "city", "governorate", "category_tag", "phone", "hero_image", "postcard_content"]
    },
    "Deal": {
      "title": "Business Deal",
      "description": "A discount or offer from a business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessLogo": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discount": { "type": "integer" },
        "expiresIn": { "type": "string" },
        "claimed": { "type": "integer" },
        "total": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "title", "discount", "total"]
    },
    "Story": {
      "title": "Community Story",
      "description": "A short-lived visual story shared by a user or business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "avatar": { "type": "string" },
        "thumbnail": { "type": "string" },
        "media": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["business", "community"] },
        "aiVerified": { "type": "boolean" },
        "isLive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "media", "type", "createdAt"]
    },
    "Event": {
      "title": "Local Event",
      "description": "An event happening in Iraq.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "governorate": { "type": "string" },
        "city": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "integer" },
        "attendees": { "type": "integer" },
        "aiRecommended": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "date", "venue", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social feed posts."
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business directory entries."
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Tracks likes to prevent duplicates."
    },
    "/business_postcards/{postcardId}": {
      "schema": "BusinessPostcard",
      "description": "AI-curated business postcards."
    },
    "/deals/{dealId}": {
      "schema": "Deal",
      "description": "Business deals and offers."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Community and business stories."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Local events."
    }
  }
}
